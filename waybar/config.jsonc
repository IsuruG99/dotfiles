
{
    "layer": "top",
    "position": "top",
    "height": 28,
    "spacing": 2,

    "modules-left": [
        "hyprland/window"
    ],
    "modules-center": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "custom/gpu",
        "cpu",
        "memory",
        "network",
        "pulseaudio",
        "clock",
        "tray",
        "custom/notification"
    ],

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Module definitions
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "у°јЏ",
            "2": "у°јЏ",
            "3": "у°јЏ",
            "4": "у°јЏ",
            "5": "у°јЏ",
            "6": "у°јЏ",
            "7": "у°јЏ",
            "8": "у°јЏ",
            "9": "у°јЏ",
            "10": "у°јЏ",
            "active": "у°®Ї",
            "default": "у°јЏ"
        }
    },

    "hyprland/window": {
        "max-length": 50
    },

    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits",
        "format": "GPU: {}%",
        "interval": 3,
        "return-type": "text"
    },

    "cpu": {
        "format": "CPU: {usage}%"
    },

    "memory": {
        "format": "RAM: {used:0.1f}GB"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) п‡«",
        "format-ethernet": "{ipaddr}/{cidr} пЂ’",
        "format-disconnected": "Disconnected вљ ",
        "tooltip-format": "{ifname}: {ipaddr}"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "Muted {icon}",
        "format-icons": {
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "scroll-step": 5,
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": "{:%I:%M %p}",
        "format-alt": "{:%Y-%m-%d}"
    },

    "tray": {
        "spacing": 10
    },
    "custom/notification": {
      "format": "{icon}",
      "format-icons": {
        "notification":
          "<span rise='8pt'>п‚ў<span foreground='red'><sup>п‘„</sup></span></span>",
        "none": "п‚ў",
        "dnd-notification":
          "<span rise='8pt'>п‚ў<span foreground='red'><sup>п‘„</sup></span></span>",
        "dnd-none": "п‡·",
        "inhibited-notification":
          "<span rise='8pt'>п‚ў<span foreground='red'><sup>п‘„</sup></span></span>",
        "inhibited-none": "п‚ў",
        "dnd-inhibited-notification":
          "<span rise='8pt'>п‡·<span foreground='red'><sup>п‘„</sup></span></span>",
        "dnd-inhibited-none": "п‡·"
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true,
      "tooltip": false
    }
  } 
}

