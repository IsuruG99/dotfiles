    /* background-color: #2980b9; */
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#tray > .needs-attention {
    -gtk-icon-effect: highlight;
    background-color: #eb4d4b;
}

#idle_inhibitor {
    background-color: #2d3436;
}

#idle_inhibitor.activated {
    border: none;
    border-radius: 0;
    font-family: JetBrainsMono Nerd Font, sans-serif;  /* or your font */
    font-size: 13px;
    min-height: 0;
}

window#waybar {
    background: rgba(30, 30, 46, 0.85);   /* catppuccin mocha base or similar dark */
    color: #cdd6f4;
    transition: none;
}

#workspaces button {
    padding: 0 8px;
    color: #89b4fa;
}

#workspaces button.active {
    background: #45475a;
    color: #b4befe;
}

#custom-gpu, #cpu, #memory, #network, #pulseaudio, #clock {
    padding: 0 10px;
    margin: 0 3px;
    color: #cdd6f4;
}

#custom-gpu {
    color: #f9e2af;     /* soft yellow/orange for GPU – gaming feel */
}

#cpu {
    color: #fab387;     /* peach for CPU */
}

#memory {
    color: #f38ba8;     /* red-pink for RAM */
}

#network {
    color: #94e2d5;     /* teal for network */
}

#clock {
    color: #89dceb;
}

tooltip {
    background: #1e1e2e;
    border: 1px solid #45475a;
}
